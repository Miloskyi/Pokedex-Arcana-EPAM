# ── LLM — Ollama (local, no API key needed) ─────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Tracing (disabled by default for local dev) ──────────────────────────────
OPENAI_API_KEY=ollama-local
LANGCHAIN_API_KEY=no-tracing
LANGCHAIN_TRACING_V2=false

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=pokedex
POSTGRES_PASSWORD=pokedex_secret
POSTGRES_DB=pokedex_arcana
DATABASE_URL=postgresql://pokedex:pokedex_secret@postgres:5432/pokedex_arcana

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ── Application ──────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
FRONTEND_PORT=3000
LOG_LEVEL=INFO
